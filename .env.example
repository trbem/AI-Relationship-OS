APP_NAME=Relationship OS API
ENVIRONMENT=development
API_PREFIX=/api
# Leave DATABASE_URL unset for the Windows standalone SQLite database.
# DATABASE_URL=postgresql+psycopg://relationship_os:relationship_os@localhost:5432/relationship_os
REDIS_URL=redis://localhost:6379/0
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=relationship-os
LLM_API_KEY=
LLM_BASE_URL=https://api.xiaomimimo.com/v1
LLM_TIMEOUT_SECONDS=30
LLM_TEMPERATURE=0.2
LLM_FALLBACK_ENABLED=true
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_TIMEOUT_SECONDS=45
OLLAMA_MODEL=gemma4:e4b
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=local-hash-v1
COMPLETION_MODEL=mimo-v2.5
# JWT and local settings keys are generated automatically and protected locally.
